{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "ros_interface",
  "rules": {
    "source_file": {
      "type": "CHOICE",
      "members": [
        {
          "type": "FIELD",
          "name": "message",
          "content": {
            "type": "REPEAT",
            "content": {
              "type": "SYMBOL",
              "name": "_statement"
            }
          }
        },
        {
          "type": "SYMBOL",
          "name": "service"
        },
        {
          "type": "SYMBOL",
          "name": "action"
        }
      ]
    },
    "service": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "request",
          "content": {
            "type": "REPEAT",
            "content": {
              "type": "SYMBOL",
              "name": "_statement"
            }
          }
        },
        {
          "type": "SYMBOL",
          "name": "separator"
        },
        {
          "type": "FIELD",
          "name": "response",
          "content": {
            "type": "REPEAT",
            "content": {
              "type": "SYMBOL",
              "name": "_statement"
            }
          }
        }
      ]
    },
    "action": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "goal",
          "content": {
            "type": "REPEAT",
            "content": {
              "type": "SYMBOL",
              "name": "_statement"
            }
          }
        },
        {
          "type": "SYMBOL",
          "name": "separator"
        },
        {
          "type": "FIELD",
          "name": "result",
          "content": {
            "type": "REPEAT",
            "content": {
              "type": "SYMBOL",
              "name": "_statement"
            }
          }
        },
        {
          "type": "SYMBOL",
          "name": "separator"
        },
        {
          "type": "FIELD",
          "name": "feedback",
          "content": {
            "type": "REPEAT",
            "content": {
              "type": "SYMBOL",
              "name": "_statement"
            }
          }
        }
      ]
    },
    "_statement": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "constant"
        },
        {
          "type": "SYMBOL",
          "name": "field"
        }
      ]
    },
    "separator": {
      "type": "STRING",
      "value": "---"
    },
    "field": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "type",
          "content": {
            "type": "SYMBOL",
            "name": "_type"
          }
        },
        {
          "type": "FIELD",
          "name": "name",
          "content": {
            "type": "SYMBOL",
            "name": "identifier"
          }
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "FIELD",
              "name": "default",
              "content": {
                "type": "SYMBOL",
                "name": "field_default"
              }
            },
            {
              "type": "BLANK"
            }
          ]
        }
      ]
    },
    "constant": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "type",
          "content": {
            "type": "SYMBOL",
            "name": "primitive_type"
          }
        },
        {
          "type": "FIELD",
          "name": "name",
          "content": {
            "type": "SYMBOL",
            "name": "const_identifier"
          }
        },
        {
          "type": "STRING",
          "value": "="
        },
        {
          "type": "FIELD",
          "name": "value",
          "content": {
            "type": "SYMBOL",
            "name": "primitive_value"
          }
        }
      ]
    },
    "identifier": {
      "type": "PATTERN",
      "value": "[a-z](?:[a-z0-9_]?[a-z0-9]+)*"
    },
    "const_identifier": {
      "type": "PATTERN",
      "value": "[A-Z](?:[A-Z0-9_]?[A-Z0-9]+)*"
    },
    "field_default": {
      "type": "SYMBOL",
      "name": "value"
    },
    "_type": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "_base_type"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "array"
            },
            {
              "type": "BLANK"
            }
          ]
        }
      ]
    },
    "_base_type": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "primitive_type"
        },
        {
          "type": "SYMBOL",
          "name": "custom_type"
        },
        {
          "type": "SYMBOL",
          "name": "external_custom_type"
        }
      ]
    },
    "custom_type": {
      "type": "PATTERN",
      "value": "[A-Z][A-Za-z0-9]*"
    },
    "package_specifier": {
      "type": "PATTERN",
      "value": "([a-z](?:[a-z0-9_]?[a-z0-9]+)*)/"
    },
    "external_custom_type": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "package_specifier"
        },
        {
          "type": "SYMBOL",
          "name": "custom_type"
        }
      ]
    },
    "primitive_type": {
      "type": "CHOICE",
      "members": [
        {
          "type": "STRING",
          "value": "bool"
        },
        {
          "type": "STRING",
          "value": "byte"
        },
        {
          "type": "STRING",
          "value": "char"
        },
        {
          "type": "PATTERN",
          "value": "float(?:32|64)"
        },
        {
          "type": "PATTERN",
          "value": "u?int(?:8|16|32|64)"
        },
        {
          "type": "SYMBOL",
          "name": "string_type"
        },
        {
          "type": "STRING",
          "value": "duration"
        },
        {
          "type": "STRING",
          "value": "time"
        }
      ]
    },
    "string_type": {
      "type": "SEQ",
      "members": [
        {
          "type": "PATTERN",
          "value": "w?string"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "FIELD",
              "name": "bound",
              "content": {
                "type": "SEQ",
                "members": [
                  {
                    "type": "STRING",
                    "value": "<="
                  },
                  {
                    "type": "SYMBOL",
                    "name": "integer"
                  }
                ]
              }
            },
            {
              "type": "BLANK"
            }
          ]
        }
      ]
    },
    "array": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "["
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SEQ",
              "members": [
                {
                  "type": "CHOICE",
                  "members": [
                    {
                      "type": "STRING",
                      "value": "<="
                    },
                    {
                      "type": "BLANK"
                    }
                  ]
                },
                {
                  "type": "SYMBOL",
                  "name": "integer"
                }
              ]
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "STRING",
          "value": "]"
        }
      ]
    },
    "comment": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "#"
        },
        {
          "type": "PATTERN",
          "value": ".*"
        }
      ]
    },
    "value": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "primitive_value"
        },
        {
          "type": "SYMBOL",
          "name": "array_value"
        }
      ]
    },
    "primitive_value": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "integer"
        },
        {
          "type": "SYMBOL",
          "name": "string"
        },
        {
          "type": "SYMBOL",
          "name": "float"
        },
        {
          "type": "SYMBOL",
          "name": "bool"
        }
      ]
    },
    "string": {
      "type": "CHOICE",
      "members": [
        {
          "type": "PATTERN",
          "value": "\"(?:[^\"]|\\\\\")*\""
        },
        {
          "type": "PATTERN",
          "value": "'(:?[^']|\\\\')*'"
        }
      ]
    },
    "integer": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "_decimal_integer"
        },
        {
          "type": "SYMBOL",
          "name": "_binary_integer"
        },
        {
          "type": "SYMBOL",
          "name": "_hexadecimal_integer"
        },
        {
          "type": "SYMBOL",
          "name": "_octal_integer"
        }
      ]
    },
    "_decimal_integer": {
      "type": "PATTERN",
      "value": "[+-]?[0-9_]+"
    },
    "_binary_integer": {
      "type": "PATTERN",
      "value": "[+-]?0[bB][01_]+"
    },
    "_hexadecimal_integer": {
      "type": "PATTERN",
      "value": "[+-]?0[xX][a-f0-9A-F_]+"
    },
    "_octal_integer": {
      "type": "PATTERN",
      "value": "[+-]?0[oO][0-7_]+"
    },
    "float": {
      "type": "CHOICE",
      "members": [
        {
          "type": "PATTERN",
          "value": "[+-]?\\d+\\.\\d+(?:[eE][+-]?\\d+)?"
        },
        {
          "type": "PATTERN",
          "value": "[+-]?\\d+[eE][+-]?\\d+"
        }
      ]
    },
    "bool": {
      "type": "CHOICE",
      "members": [
        {
          "type": "STRING",
          "value": "True"
        },
        {
          "type": "STRING",
          "value": "true"
        },
        {
          "type": "STRING",
          "value": "False"
        },
        {
          "type": "STRING",
          "value": "false"
        }
      ]
    },
    "array_value": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "["
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SEQ",
              "members": [
                {
                  "type": "REPEAT",
                  "content": {
                    "type": "SEQ",
                    "members": [
                      {
                        "type": "SYMBOL",
                        "name": "primitive_value"
                      },
                      {
                        "type": "STRING",
                        "value": ","
                      }
                    ]
                  }
                },
                {
                  "type": "SYMBOL",
                  "name": "primitive_value"
                }
              ]
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "STRING",
          "value": "]"
        }
      ]
    }
  },
  "extras": [
    {
      "type": "PATTERN",
      "value": "\\s"
    },
    {
      "type": "SYMBOL",
      "name": "comment"
    }
  ],
  "conflicts": [],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}